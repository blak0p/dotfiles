#!/usr/bin/env fish
#
# borrar-switch — Elimina juegos de Switch con sus DLCs y actualizaciones
#
# Uso: borrar-switch [--dry-run] ["Nombre del juego"]
#
# Con nombre: filtra y borra todos los que matcheen.
# Sin nombre: selección interactiva multi-select con fzf.

set ROMS /mnt/Juegos/Emulation/roms/switch
set UPDATES $ROMS/updates
set DLC $ROMS/dlc

set DRY_RUN false

if not command -v fzf >/dev/null
    echo "Este script necesita fzf instalado para la selección interactiva."
    echo "Instálalo (por ejemplo: sudo pacman -S fzf / sudo apt install fzf) y vuelve a intentarlo."
    exit 1
end

argparse 'dry-run' 'h/help' -- $argv
or exit 1

if set -q _flag_help
    echo "Uso: "(status basename)" [--dry-run] [\"Nombre del juego\"]"
    echo ""
    echo "  --dry-run    Muestra qué se borraría sin borrar nada"
    exit 0
end

if set -q _flag_dry_run
    set DRY_RUN true
end

function titleid_from_file
    basename $argv[1] | grep -oP '\[\K[0-9A-Fa-f]{16}(?=\])' | head -1
end

function titleid_prefix
    string sub -l 13 -- $argv[1]
end

function find_dlc_for
    set prefix $argv[1]
    if test -d $DLC
        for f in (find $DLC -maxdepth 1 \( -name "*.nsp" -o -name "*.nsz" \))
            set tid (titleid_from_file $f)
            if test -n "$tid"; and test (titleid_prefix $tid) = "$prefix"
                echo $f
            end
        end
    end
end

function find_updates_for
    set prefix $argv[1]
    if test -d $UPDATES
        for f in (find $UPDATES -maxdepth 1 \( -name "*.nsp" -o -name "*.nsz" \))
            set tid (titleid_from_file $f)
            if test -n "$tid"; and test (titleid_prefix $tid) = "$prefix"
                echo $f
            end
        end
    end
end

function delete_items
    set -l items $argv
    set -l unique
    for item in $items
        test -z "$item"; and continue
        if not contains -- $item $unique
            set unique $unique $item
            set -l rel (string replace -- "$ROMS/" "" $item)
            echo "  $rel"
        end
    end
    if test $DRY_RUN = true
        echo "  [DRY-RUN] — no se borró nada"
    else
        if test (count $unique) -gt 0
            rm -f $unique
        end
    end
end

function game_label
    set bname (basename $argv[1])
    echo $bname | sed 's/ *\[.*\]//g; s/ *([^)]*)//g; s/ *$//'
end

# --- recopilar juegos base ---
set base_games (find $ROMS -maxdepth 1 \( -name "*.nsp" -o -name "*.nsz" \) | sort)

if test (count $base_games) -eq 0
    echo "No hay juegos instalados en $ROMS"
    exit 1
end

# --- filtro por nombre (argumento posicional) ---
set GAME_FILTER $argv[1]

if test -n "$GAME_FILTER"
    set SELECTED
    for game in $base_games
        set bname (basename $game)
        if echo $bname | grep -qi -- "$GAME_FILTER"
            set SELECTED $SELECTED $game
        end
    end

    if test (count $SELECTED) -eq 0
        echo "No se encontró ningún juego que coincida con \"$GAME_FILTER\""
        exit 1
    end
else
    # --- modo interactivo con fzf ---
    set fzf_input
    for game in $base_games
        set label (game_label $game)
        set fzf_input $fzf_input $game\t$label
    end

    set fzf_output (printf '%s\n' $fzf_input | fzf \
        --multi \
        --delimiter=\t \
        --with-nth=2 \
        --prompt="Selecciona juegos a borrar> ")

    if test (count $fzf_output) -eq 0
        echo "Cancelado, no se seleccionó nada."
        exit 0
    end

    set SELECTED
    for line in $fzf_output
        set path (string split -f 1 -- \t $line)
        test -n "$path"; and set SELECTED $SELECTED $path
    end

    if test (count $SELECTED) -eq 0
        echo "Cancelado, no se seleccionó nada."
        exit 0
    end
end

# --- armar lista completa a borrar ---
set to_delete

for game in $SELECTED
    set tid (titleid_from_file $game)
    set to_delete $to_delete $game

    if test -n "$tid"
        set prefix (titleid_prefix $tid)

        for dlc in (find_dlc_for $prefix)
            test -n "$dlc"; and set to_delete $to_delete $dlc
        end

        for update in (find_updates_for $prefix)
            test -n "$update"; and set to_delete $to_delete $update
        end
    end
end

# --- resumen ---
echo ""
echo "========================================"
echo "Se va a eliminar:"
echo "========================================"
set seen
for item in $to_delete
    test -z "$item"; and continue
    set rel (string replace -- "$ROMS/" "" $item)
    if not contains -- $rel $seen
        echo "  $rel"
        set seen $seen $rel
    end
end

echo ""
echo "Total: "(count $to_delete)" archivos"
test $DRY_RUN = true; and echo "Modo DRY-RUN — no se borrará nada realmente"

# --- confirmación ---
if test $DRY_RUN = false
    echo ""
    read -P "Eliminar? (s/N): " confirm
    if test "$confirm" != s -a "$confirm" != S
        echo "Cancelado."
        exit 0
    end
end

# --- borrar ---
delete_items $to_delete

if test $DRY_RUN = true
    echo ""
    echo "Simulación completa."
else
    echo ""
    echo "Eliminado."
end
