# --- FUENTES ---
# Necesitas una Nerd Font para ver iconos (como JetBrainsMono Nerd Font)
font_family      JetBrainsMono Nerd Font
bold_font        auto
italic_font      auto
font_size        11.0

# --- APARIENCIA ---
# La opacidad (0.0 a 1.0). 0.85 suele ser el "punto dulce" entre estilo y lectura.
background_opacity 0.85

# Margen interno para que el texto no toque los bordes de la ventana
window_padding_width 12

# --- COMPORTAMIENTO ---
# Elimina el molesto sonido de campana (el "beep")
enable_audio_bell no

# El cursor: ¿Quieres que parpadee o que sea estático?
cursor_shape beam
cursor_blink_interval 0


# BEGIN_KITTY_THEME
# Adapta Nokto Maia
include current-theme.conf
# END_KITTY_THEME