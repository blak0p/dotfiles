#!/bin/bash

ROMS="/run/media/system/Juegos/Emulation/roms/switch"
UPDATES="$ROMS/updates"
DLC="$ROMS/dlc"

mkdir -p "$UPDATES"
mkdir -p "$DLC"

# 1. Reorganizar carpetas de torrents
for dir in "$ROMS"/*/; do
    [[ "$dir" == */updates/ ]] && continue
    [[ "$dir" == */dlc/ ]] && continue
    
    # Mover juego base [v0] con TitleID terminado en 000
    find "$dir" -maxdepth 1 \( -name "*.nsz" -o -name "*.nsp" \) -name "*\[v0\]*" | while read f; do
        basename=$(basename "$f")
        titleid=$(echo "$basename" | grep -oP '\[\K[0-9A-Fa-f]{16}(?=\])' | head -1)
        if [[ "${titleid: -3}" == "000" ]]; then
            mv "$f" "$ROMS/"
        else
            mv "$f" "$DLC/"
        fi
    done
    
    # Mover actualizaciones (todo lo que no sea [v0])
    find "$dir" -maxdepth 1 \( -name "*.nsz" -o -name "*.nsp" \) ! -name "*\[v0\]*" | while read f; do
        mv "$f" "$UPDATES/"
    done
    
    # Borrar carpeta entera
    rm -rf "$dir"
done

# 2. Descomprimir NSZ
nsz -D "$ROMS"/*.nsz 2>/dev/null
nsz -D "$UPDATES"/*.nsz 2>/dev/null
nsz -D "$DLC"/*.nsz 2>/dev/null

# 3. Borrar NSZ originales tras descomprimir
rm -f "$ROMS"/*.nsz
rm -f "$UPDATES"/*.nsz
rm -f "$DLC"/*.nsz

# 4. Abrir Steam ROM Manager para añadir a Steam
