#!/usr/bin/env fish

set my_pid %self
set my_shell_pid (ps -o ppid= -p $my_pid | string trim)

set zellij_pids (pgrep -x zellij)
set keep_zellij (echo $zellij_pids | tr ' ' '\n' | sort -n | tail -1)

set protected $my_shell_pid $keep_zellij

for pid in (ps -u (whoami) -o pid= | string trim)
    if not contains $pid $protected
        kill -TERM $pid 2>/dev/null
    end
end

sleep 1

for pid in (ps -u (whoami) -o pid= | string trim)
    if not contains $pid $protected
        kill -KILL $pid 2>/dev/null
    end
end

echo "Listo. Solo quedan vivos: zellij ($keep_zellij) y este fish ($my_shell_pid)."
