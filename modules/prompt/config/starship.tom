# No queremos que la terminal ocupe dos líneas
add_newline = false

[character]
success_symbol = "[➜](bold green)"
error_symbol = "[➜](bold red)"

[directory]
style = "bold cyan"
truncation_length = 3
truncation_symbol = "…/"

[git_branch]
symbol = " "
style = "bold purple"

[python]
symbol = "🐍 "
format = "via [${symbol}${version}]($style) "
style = "bold yellow"
