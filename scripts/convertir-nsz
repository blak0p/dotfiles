#!/bin/bash
set -euo pipefail

ROMS="/mnt/Juegos/Emulation/roms/switch"
UPDATES="$ROMS/updates"
DLC="$ROMS/dlc"

# Protecciones de Bash
shopt -s nullglob # Los globs (*) se expanden a vacío si no hay coincidencias

mkdir -p "$UPDATES" "$DLC"

# Función para clasificar y mover de forma segura
mover_archivo() {
  local archivo="$1"
  local nombre_base="${archivo##*/}"
  local destino=""

  # Extraer TitleID usando regex nativo de Bash (evita dependencia de grep -P)
  local titleid=""
  if [[ "$nombre_base" =~ \[([0-9A-Fa-f]{16})\] ]]; then
    titleid="${BASH_REMATCH[1]}"
  fi

  # Clasificación basada en [v0] y TitleID
  if [[ "$nombre_base" == *"[v0]"* ]]; then
    # Si tiene [v0] y el TitleID acaba en 000, es juego base.
    # Si el TitleID no acaba en 000 (o no existe), es DLC.
    if [[ "${titleid: -3}" == "000" ]]; then
      destino="$ROMS"
    else
      destino="$DLC"
    fi
  else
    # Si no tiene [v0], asumimos que es actualización
    destino="$UPDATES"
  fi

  # Mover de forma segura (mv -n = no clobber, no sobrescribe)
  if [[ -e "$destino/$nombre_base" ]]; then
    echo "ADVERTENCIA: '$nombre_base' ya existe en '$destino'. No se sobrescribió." >&2
  else
    mv -n "$archivo" "$destino/"
  fi
}

# 1. Reorganizar carpetas de torrents (Búsqueda recursiva)
for dir in "$ROMS"/*/; do
  [[ "$dir" == "$UPDATES/" || "$dir" == "$DLC/" ]] && continue

  # Usar process substitution en lugar de tubería para evitar subshell
  # -type f asegura que solo procesamos archivos
  # Delimitamos con null character para soportar cualquier nombre de archivo
  while IFS= read -r -d '' f; do
    mover_archivo "$f"
  done < <(find "$dir" -type f \( -name "*.nsz" -o -name "*.nsp" \) -print0)

  # Borrado seguro de la carpeta contenedora
  # Primero verificamos que NO haya quedado ningún .nsp o .nsz (indicaría un fallo de mv)
  if find "$dir" -type f \( -name "*.nsz" -o -name "*.nsp" \) -print -quit | grep -q .; then
    echo "ERROR CRÍTICO: Aún quedan archivos NSP/NSZ en '$dir'. No se borrará la carpeta para evitar pérdida de datos." >&2
  else
    # Si las ROMs se movieron con éxito, borramos la carpeta y los archivos basura (.nfo, .txt, etc.)
    rm -rf "$dir"
  fi
done

# 2 & 3. Descomprimir NSZ y borrar SOLO si tuvo éxito
procesar_nsz() {
  local dir="$1"
  local archivos=("$dir"/*.nsz)

  # Si el array está vacío (gracias a nullglob), salir de la función
  [[ ${#archivos[@]} -eq 0 ]] && return

  for f in "${archivos[@]}"; do
    echo "Descomprimiendo: $f"
    # Ejecutar nsz. Si falla (set -e), el script se detiene antes de borrar.
    if nsz -D "$f"; then
      # Solo borramos el .nsz si nsz retornó 0 (éxito)
      rm -f "$f"
    else
      echo "ERROR: Fallo al descomprimir '$f'. El archivo original se conserva." >&2
    fi
  done
}

procesar_nsz "$ROMS"
procesar_nsz "$UPDATES"
procesar_nsz "$DLC"

echo "Proceso completado con éxito."
# 4. Abrir Steam ROM Manager para añadir a Steam
