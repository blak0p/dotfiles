#!/usr/bin/env fish

set ROMS "/run/media/system/Juegos/Emulation/roms/switch"
set UPDATES "$ROMS/updates"
set DLC "$ROMS/dlc"

mkdir -p "$UPDATES"
mkdir -p "$DLC"

# 1. Reorganizar carpetas de torrents
for dir in $ROMS/*/
    if string match -q "*/updates/" -- "$dir"; or string match -q "*/dlc/" -- "$dir"
        continue
    end

    # Mover juego base [v0] con TitleID terminado en 000
    for f in $dir*.nsz $dir*.nsp
        test -e "$f"; or continue
        if string match -q "*\[v0\]*" -- "$f"
            set titleid (string match -r '\[([0-9A-Fa-f]{16})\]' -- (basename "$f"))[2]
            if string match -q "*000" -- "$titleid"
                mv "$f" "$ROMS/"
            else
                mv "$f" "$DLC/"
            end
        else
            mv "$f" "$UPDATES/"
        end
    end

    rm -rf "$dir"
end

# 2. Descomprimir NSZ
set roms_nsz $ROMS/*.nsz
set updates_nsz $UPDATES/*.nsz
set dlc_nsz $DLC/*.nsz

test -n "$roms_nsz"; and nsz -D $roms_nsz
test -n "$updates_nsz"; and nsz -D $updates_nsz
test -n "$dlc_nsz"; and nsz -D $dlc_nsz

# 3. Borrar NSZ originales tras descomprimir
test -n "$roms_nsz"; and rm -f $roms_nsz
test -n "$updates_nsz"; and rm -f $updates_nsz
test -n "$dlc_nsz"; and rm -f $dlc_nsz
